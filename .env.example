# ============================================================
# iPig System 環境變數設定範本
# ============================================================
# 複製此檔案為 .env 並填入正式值
#   cp .env.example .env
#
# ⚠️ 請勿將 .env 加入版本控制
#
# 何者放 .env、何者放 DB（system_settings）請見：
#   docs/operations/ENV_AND_DB.md
# ============================================================

# =========================
# 伺服器
# =========================
# 後端監聽位址
HOST=0.0.0.0
# 後端監聽埠號
PORT=3000

# =========================
# PostgreSQL 資料庫
# =========================
# 資料庫使用者名稱
POSTGRES_USER=postgres
# 資料庫密碼（⚠️ 必須修改為強密碼）
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
# 資料庫名稱
POSTGRES_DB=ipig_db
# 對外映射的 PostgreSQL 埠號（host 端，5432 為 PostgreSQL 預設，5433 常用於本機避開衝突）
POSTGRES_PORT=5433

# 【必填】後端連接資料庫的 URL
# 格式: postgres://<user>:<password>@<host>:<port>/<db>
# Docker 內部使用 service name 'db'；本機開發可改 localhost
DATABASE_URL=postgres://postgres:CHANGE_THIS_PASSWORD@db:5432/ipig_db
# 編譯時若無資料庫：設為 true 使用 .sqlx 快取（backend/.cargo/config.toml 已預設）
# SQLX_OFFLINE=true
# 連線池最大連線數
DATABASE_MAX_CONNECTIONS=10
# 連線池最小連線數（預熱）
# DATABASE_MIN_CONNECTIONS=5
# 取得連線逾時秒數
# DATABASE_ACQUIRE_TIMEOUT_SECONDS=30
# 個別 SQL 查詢執行上限（毫秒）；0 = 停用（開發期間可設 0，生產建議 30000）
# DATABASE_STATEMENT_TIMEOUT_MS=30000
# 連線失敗重試次數
DATABASE_RETRY_ATTEMPTS=5
# 每次重試間隔（秒）
DATABASE_RETRY_DELAY_SECONDS=5

# =========================
# JWT 認證（ES256 非對稱金鑰）
# =========================
# 【必填】EC P-256 私鑰 PEM（用於簽發 JWT）
# 產生方式（只需執行一次，妥善保存私鑰！）:
#   openssl ecparam -name prime256v1 -genkey -noout | openssl pkcs8 -topk8 -nocrypt > secrets/jwt_ec_private_key.pem
#   openssl ec -in secrets/jwt_ec_private_key.pem -pubout > secrets/jwt_ec_public_key.pem
#
# 方式一：直接指定 PEM 檔案路徑（推薦 Docker Secrets）
JWT_EC_PRIVATE_KEY_FILE=./secrets/jwt_ec_private_key.pem
JWT_EC_PUBLIC_KEY_FILE=./secrets/jwt_ec_public_key.pem
#
# 方式二：直接設定 PEM 內容（本機開發快速使用）
# JWT_EC_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----
# JWT_EC_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----

# Access Token 有效期（分鐘）
JWT_EXPIRATION_MINUTES=360

# Refresh Token 有效期（天數）
JWT_REFRESH_EXPIRATION_DAYS=7
# 每位使用者同時可擁有的最大活躍 Session 數量
MAX_SESSIONS_PER_USER=5

# =========================
# 帳號鎖定（SEC-20 登入失敗鎖定）
# =========================
# 關閉帳號鎖定（true=關閉，開發環境適用；正式環境請保持 false）
DISABLE_ACCOUNT_LOCKOUT=false
# 鎖定前允許的登入失敗次數（預設 5）
ACCOUNT_LOCKOUT_MAX_ATTEMPTS=5
# 鎖定時間（分鐘），此時間內失敗次數達上限即鎖定（預設 15）
ACCOUNT_LOCKOUT_DURATION_MINUTES=15

# 【正式環境必填】管理員初始密碼（首次建立管理員帳號時使用）
# ⚠️ 正式環境請使用強密碼；首次登入後可強制要求修改密碼
# 本機／E2E：可設為 admin123，並用下方指令同步 DB 內 admin 密碼：
#   docker compose run --rm api /app/create_admin
ADMIN_INITIAL_PASSWORD=CHANGE_THIS_ADMIN_PASSWORD

# =========================
# 稽核日誌完整性（SEC-34）
# =========================
# HMAC-SHA256 密鑰，用於稽核日誌防篡改雜湊鏈
# ⚠️ 必須產生強隨機值，且與 JWT_SECRET 不同
# 產生方式 (PowerShell):
#   [Convert]::ToBase64String((1..32 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
# 產生方式 (Linux/macOS):
#   openssl rand -base64 32
AUDIT_HMAC_KEY=CHANGE_THIS_TO_RANDOM_BASE64_STRING

# =========================
# 電子郵件（SMTP）
# =========================
# 以下為「預設／備援」：後台「系統設定」存進 DB 後會覆蓋 .env，無須重啟即可更換 SMTP。
# SMTP 伺服器位址（留空則停用郵件功能）
SMTP_HOST=smtp.gmail.com
# SMTP 埠號
SMTP_PORT=587
# SMTP 使用者名稱
SMTP_USERNAME=your-email@gmail.com
# SMTP 密碼或應用程式密碼
# Gmail 需使用「應用程式密碼」: https://myaccount.google.com/apppasswords
SMTP_PASSWORD=CHANGE_THIS_SMTP_PASSWORD
# 寄件者信箱
SMTP_FROM_EMAIL=your-email@gmail.com
# 寄件者顯示名稱
SMTP_FROM_NAME=iPig System

# =========================
# 應用程式
# =========================
# 前端 URL（用於郵件中的連結）
APP_URL=https://your-domain.example.com
# 前端 Nginx 對外埠號
WEB_PORT=8080
# 檔案上傳儲存路徑
UPLOAD_DIR=./uploads

# =========================
# Gotenberg PDF 服務
# =========================
# Gotenberg 服務 URL（Docker 內部使用 service name 'gotenberg'）
# 本機開發需另起 Gotenberg 容器：docker run -p 3001:3000 gotenberg/gotenberg:8
GOTENBERG_URL=http://gotenberg:3000

# =========================
# PDF Service（Phase 1 血液檢查 PDF）
# =========================
# FastAPI PDF 渲染服務，位於 Rust backend 與 Gotenberg 之間
PDF_SERVICE_URL=http://pdf-service:3200
# 內部服務認證 token（X-Internal-Token），不可外洩；正式環境務必更換
PDF_SERVICE_TOKEN=change-me-pdf-service-token

# =========================
# 打卡地理圍籬
# =========================
# 允許打卡的 IP 範圍（CIDR 格式，逗號分隔可設定多組）
# 範例: 10.0.4.0/24,192.168.1.0/24
ALLOWED_CLOCK_IP_RANGES=10.0.4.0/24

# 辦公室 GPS 座標（緯度）
CLOCK_OFFICE_LATITUDE=24.654063
# 辦公室 GPS 座標（經度）
CLOCK_OFFICE_LONGITUDE=120.784917
# GPS 允許半徑（公尺）
CLOCK_GPS_RADIUS_METERS=200

# =========================
# 安全設定
# =========================
# Cookie Secure 旗標
#   true  = 僅 HTTPS 傳送 cookie（生產環境）
#   false = 允許 HTTP（開發環境）
COOKIE_SECURE=false
# Cookie 所屬網域（選用，未設定則使用 request host）
# 範例: .your-domain.example.com
# COOKIE_DOMAIN=

# 是否載入開發測試用帳號
#   true  = 啟動時自動建立測試帳號（開發環境）
#   false = 不建立（生產環境）
SEED_DEV_USERS=true

# 是否信任反向代理的 IP header（X-Forwarded-For、X-Real-IP）
#   true  = 使用 proxy header 中的 IP（有 Nginx/Cloudflare 前端時）
#   false = 僅使用 socket 直連 IP
TRUST_PROXY_HEADERS=true

# CORS 允許的 Origin（逗號分隔）
# 範例: http://localhost:8080,https://your-domain.example.com
CORS_ALLOWED_ORIGINS=http://localhost:8080

# =========================
# 整合測試（僅開發/CI 使用）
# =========================
# 測試用資料庫 URL（CI 或本機跑整合測試時使用，未設則沿用 DATABASE_URL）
# TEST_DATABASE_URL=postgres://postgres:password@localhost:5432/ipig_db_test
# TEST_ADMIN_EMAIL=admin@example.com
# TEST_ADMIN_PASSWORD=your_test_password
# TEST_USER_PASSWORD=your_test_user_password

# =========================
# E2E 測試（Playwright）
# =========================
# 建立測試帳號: cargo run --bin create_test_user <email> <password> <name>
# E2E_BASE_URL=http://localhost:8080
# E2E_USER_EMAIL=e2e-test@ipig.local
# E2E_USER_PASSWORD=your_e2e_password
# E2E_ADMIN_EMAIL=admin@ipigsystem.asia
# E2E_ADMIN_PASSWORD=your_admin_password

# =========================
# 日誌格式
# =========================
# 設為 json 時啟用 JSON 結構化日誌（適合搭配 ELK/Loki）
# 預設（留空或不設定）: 人眼可讀的文字格式
RUST_LOG_FORMAT=

# =========================
# 備份設定
# =========================
# 備份排程（cron 格式，預設每天凌晨 2:00）
BACKUP_SCHEDULE=0 2 * * *
# 備份保留天數
BACKUP_RETENTION_DAYS=30
# 異地備份目標（rsync 格式，留空則跳過）
RSYNC_TARGET=
# GPG 加密備份收件者（Key ID 或 email，留空則不加密）
# 當 BACKUP_REQUIRE_ENCRYPTION=true 時為必填，留空將導致備份容器啟動失敗。
# 步驟: 1) gpg --full-generate-key  2) 匯入公鑰到容器  3) 填入 email 或 Key ID
# 範例: BACKUP_GPG_RECIPIENT=backup@example.com
BACKUP_GPG_RECIPIENT=

# =========================
# Prometheus /metrics 端點保護
# =========================
# Bearer Token 保護 /metrics 端點（留空則無認證，僅適合 Docker 內網環境）
# 設定後須同步寫入 secrets/metrics_token.txt（Prometheus 從該檔案讀取）
# 產生方式: openssl rand -hex 32
METRICS_TOKEN=

# =========================
# 監控（Prometheus + Grafana + Alertmanager）
# =========================
# docker-compose.monitoring.yml overlay 使用
# Grafana 管理員帳號
GRAFANA_ADMIN_USER=admin
# Grafana 管理員密碼（必填：monitoring overlay 無預設值，未設定時 Grafana 無法正常登入）
GRAFANA_ADMIN_PASSWORD=CHANGE_THIS_GRAFANA_PASSWORD
# Grafana SMTP（Alert 發信用）
GRAFANA_SMTP_HOST=smtp.gmail.com:587
GRAFANA_SMTP_USER=your@gmail.com
GRAFANA_SMTP_PASSWORD=your_gmail_app_password

# Alertmanager 通知（有 alertmanager.example.yml 時自動 envsubst 替換）
# Webhook URL（如 Slack、Teams、自訂 API）
ALERTMANAGER_WEBHOOK_URL=
# R24-3: Alertmanager 呼叫 ipig api webhook 時的共享 token（Bearer auth）
# 值需與 ./secrets/alertmanager_webhook_token.txt 內容一致；本機 dev 可留空關閉驗證
ALERTMANAGER_WEBHOOK_TOKEN=
# Email 通知（critical 等級）
ALERT_EMAIL_TO=admin@example.com
ALERT_EMAIL_FROM=alertmanager@ipig.system
ALERT_SMTP_HOST=smtp.example.com:587
ALERT_SMTP_USER=alertmanager@example.com
ALERT_SMTP_PASSWORD=

# =========================
# GeoIP（選用）
# =========================
# MaxMind License Key（用於自動更新 GeoLite2-City）
# 取得方式: https://www.maxmind.com/en/accounts/current/license-key
MAXMIND_LICENSE_KEY=
# GeoLite2-City.mmdb 檔案路徑
GEOIP_DB_PATH=/app/geoip/GeoLite2-City.mmdb

# =========================
# Container Registry (GHCR) — 正式環境
# =========================
# GitHub 使用者或組織名稱（用於 image path）
# GHCR_OWNER=your-github-username
# 部署的 image tag（預設 latest，回滾時可指定 commit SHA）
# IMAGE_TAG=latest

# =========================
# Watchtower 自動更新 — 正式環境
# =========================
# API token（手動觸發更新用，產生方式: openssl rand -hex 32）
# WATCHTOWER_API_TOKEN=
# 部署通知信箱
# DEPLOY_NOTIFY_EMAIL=admin@example.com
