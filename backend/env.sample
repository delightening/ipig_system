# Server
HOST=0.0.0.0
PORT=3000

# Database
# For local development, use localhost
# For Docker Compose, the API service will construct DATABASE_URL automatically
# DATABASE_URL will be constructed from POSTGRES_USER, POSTGRES_PASSWORD, POSTGRES_DB
POSTGRES_USER=postgres
POSTGRES_PASSWORD=CHANGE_THIS_PASSWORD
POSTGRES_DB=ipig_db
POSTGRES_PORT=5433
DATABASE_URL=postgres://postgres:CHANGE_THIS_PASSWORD@localhost:5432/ipig_db
DATABASE_MAX_CONNECTIONS=10
# Database connection retry settings (useful for Docker Compose environments)
DATABASE_RETRY_ATTEMPTS=5
DATABASE_RETRY_DELAY_SECONDS=5

# JWT (SEC-32: 使用 JWT_EXPIRATION_MINUTES)
# Generate a secure JWT secret using PowerShell:
# $jwt = [Convert]::ToBase64String((1..64 | ForEach-Object { Get-Random -Minimum 0 -Maximum 256 }))
# Then copy the output value here
JWT_SECRET=CHANGE_THIS_JWT_SECRET_GENERATE_USING_POWERSHELL_COMMAND
# Access token 有效分鐘數，預設 15。E2E/本機開發建議 ≥5 以利 34 個 test 一次跑完
JWT_EXPIRATION_MINUTES=15
JWT_REFRESH_EXPIRATION_DAYS=7

# Email SMTP Configuration (optional - leave SMTP_HOST empty to disable)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@ipig.local
SMTP_FROM_NAME=iPig System

# Application URL (used in email links)
APP_URL=http://localhost

# Web frontend port (for Docker Compose)
WEB_PORT=8080

# R17-4: Prometheus /metrics 端點 Bearer 認證 Token
# 設定後 Prometheus scrape 需在 HTTP header 帶 Authorization: Bearer <token>
# 未設定則 /metrics 無認證（開發環境可不設，production 強烈建議設定）
# METRICS_TOKEN=your-secure-random-token-here

# R20-5: AI 預審設定
# Anthropic API Key（必須設定才能啟用 Level 2 AI 預審）
# ANTHROPIC_API_KEY=sk-ant-api03-...
# AI 預審模型（預設 claude-haiku-4-5）
# AI_REVIEW_MODEL=claude-haiku-4-5
# 是否啟用 AI 預審（預設 true，設為 false 或 0 關閉）
# AI_REVIEW_ENABLED=true
# AI 預審 API 呼叫逾時秒數（預設 30）
# AI_REVIEW_TIMEOUT_SECS=30
