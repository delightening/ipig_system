  "query": "\n            SELECT p.id, p.ear_tag, p.iacuc_no, pr.pi_user_id as \"pi_user_id?\"\n            FROM pigs p\n            LEFT JOIN protocols pr ON p.iacuc_no = pr.iacuc_no\n            WHERE p.id = $1 AND p.is_deleted = false\n            ",
