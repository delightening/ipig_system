  "query": "\n            UPDATE amendment_review_assignments\n            SET\n                decision = $3,\n                decided_at = NOW(),\n                comment = $4\n            WHERE amendment_id = $1 AND reviewer_id = $2\n            RETURNING\n                id, amendment_id, reviewer_id, assigned_by, assigned_at,\n                decision, decided_at, comment\n            ",
