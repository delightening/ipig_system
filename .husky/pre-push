#!/bin/sh
# 在 git push 前執行完整 CI 測試（不跳過任何項目）
if command -v pwsh >/dev/null 2>&1; then
  pwsh -File scripts/run-ci-local.ps1
elif command -v powershell >/dev/null 2>&1; then
  powershell -ExecutionPolicy Bypass -File scripts/run-ci-local.ps1
else
  echo "PowerShell required for run-ci-local.ps1. Skipping pre-push CI."
  exit 0
fi
exit $?
